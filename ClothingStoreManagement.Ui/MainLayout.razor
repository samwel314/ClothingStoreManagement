@inherits LayoutComponentBase
@inject AppState AppState
@inject NavigationManager Nav

<div class="d-flex vh-100" dir="rtl">
    @if (AppState.IsLoggedIn)
    {
        <div class="d-flex flex-column flex-shrink-0 p-2 text-white bg-dark shadow-lg custom-sidebar" style="width: 250px; overflow-y: auto;">
            
<a href="/" class="d-flex align-items-center mb-2 mt-1 text-white text-decoration-none px-2">
    <i class="bi bi-tag-fill fs-4 text-primary ms-2"></i>
    
    <span class="fs-5 fw-bold" style="white-space: nowrap;">
        @ClientBaseData.Name
    </span>
</a>
            <hr class="my-2 opacity-25">
            
            <ul class="nav nav-pills flex-column p-0 gap-1">
                <li class="nav-item">
                    <NavLink class="nav-link text-white py-1 px-3 small" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-grid-1x2-fill ms-2"></i> الرئيسية
                    </NavLink>
                </li>

                <li class="mt-2 mb-1 px-2">
                    <small class="text-uppercase text-secondary fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">إدارة المخزن</small>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link text-white py-1 px-3 small" href="/products">
                        <i class="bi bi-box-seam-fill ms-2"></i> المنتجات
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link text-white py-1 px-3 small" href="/categories">
                        <i class="bi bi-diagram-3-fill ms-2"></i> الأقسام
                    </NavLink>
                </li>

                <li class="mt-2 mb-1 px-2">
                    <small class="text-uppercase text-secondary fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">خصائص الموديلات</small>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link text-white py-1 px-3 small" href="/colors">
                        <i class="bi bi-palette-fill ms-2"></i> الألوان
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link text-white py-1 px-3 small" href="/sizes">
                        <i class="bi bi-rulers ms-2"></i> المقاسات
                    </NavLink>
                </li>

                <li class="mt-2 mb-1 px-2">
                    <small class="text-uppercase text-secondary fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">العمليات اليومية</small>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link text-white py-1 px-3 small" href="/dashboard">
                        <i class="bi bi-pc-display-horizontal ms-2"></i> كاشير البيع
                    </NavLink>
                </li>

                @if (AppState.CurrentUser?.Role == UserRole.Admin)
                {
                    <li class="mt-2 mb-1 px-2">
                        <small class="text-uppercase text-secondary fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">الحسابات والنظام</small>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white py-1 px-3 small" href="/shift-management">
                            <i class="bi bi-safe-fill ms-2"></i> إدارة الخزنة
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white py-1 px-3 small" href="/expenses">
                            <i class="bi bi-cash-stack ms-2"></i> سجل المصاريف
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white py-1 px-3 small" href="/users">
                            <i class="bi bi-people-fill ms-2"></i> إدارة المستخدمين
                        </NavLink>
                    </li>
                }
            </ul>
            
            <hr class="mt-auto mb-2 opacity-25">
            
            <div class="d-flex align-items-center p-2 bg-light bg-opacity-10 rounded mb-1 mx-1 justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="bi bi-person-badge-fill fs-5 ms-2 text-primary"></i>
                    <div style="line-height: 1.2;">
                        <div class="fw-bold small text-truncate" style="max-width: 100px;">@AppState.CurrentUser?.UserName</div>
                        <div class="text-success fw-bold" style="font-size: 0.65rem;">
                             @(AppState.CurrentUser?.Role == UserRole.Admin ? "مدير نظام" : "كاشير")
                        </div>
                    </div>
                </div>
                <button class="btn btn-sm text-white-50 p-0 hvr-red" title="تسجيل الخروج" @onclick="Logout">
                    <i class="bi bi-box-arrow-left fs-5"></i>
                </button>
            </div>
        </div>
    }
<div class="flex-grow-1 d-flex flex-column vh-100 overflow-hidden text-dark bg-light">
    
    <header class="navbar navbar-expand bg-dark text-white px-3 shadow-sm border-bottom border-secondary border-opacity-25" 
            style="height: 52px; min-height: 52px; flex-shrink: 0; z-index: 1000;">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <small class="text-white-50"><i class="bi bi-display ms-1"></i> واجهة الإدارة</small>
            </div>
            <div class="d-flex align-items-center gap-3" dir="ltr">
                <span class="fw-bold border-start ps-3 border-secondary border-opacity-50" style="font-size: 0.85rem;">
                    <i class="bi bi-clock ms-1 text-primary"></i> @DateTime.Now.ToString("hh:mm tt")
                </span>
                <span class="badge bg-light bg-opacity-10 text-white border border-secondary border-opacity-25 px-3 py-2" style="font-size: 0.75rem;">
                    <i class="bi bi-calendar3 ms-1"></i> @DateTime.Now.ToString("yyyy/MM/dd")
                </span>
            </div>
        </div>
    </header>

    <main class="flex-grow-1 overflow-auto p-3" style="position: relative;">
        @Body
    </main>
</div></div>

@code {
    private void Logout()
    {
        AppState.Logout();
        Nav.NavigateTo("/login");
    }
}

<style>
    .custom-sidebar::-webkit-scrollbar { width: 3px; }
    .custom-sidebar::-webkit-scrollbar-thumb { background: #444; border-radius: 10px; }
    .nav-link { font-size: 0.85rem; transition: 0.2s; border-radius: 8px !important; margin-bottom: 2px; }
    .nav-link:hover { background: rgba(255,255,255,0.08); }
    .nav-link.active { background-color: #0d6efd !important; font-weight: bold; }
    .hvr-red:hover { color: #ff4d4d !important; }
    
    header.bg-dark { background-color: #212529 !important; }
</style>