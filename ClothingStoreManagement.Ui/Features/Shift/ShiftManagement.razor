@page "/shift-management"
@inject ShiftService shiftService
@inject AppState appState
@inject NavigationManager nav
@if (closeShiftModel)
{
    <div class="modal d-block shadow-lg" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            
            <div class="modal-header bg-dark text-white border-0 py-3 rounded-top-4">
                <h5 class="modal-title fw-bold w-100 text-center">إغلاق الوردية</h5>
            </div>

            <div class="modal-body p-4">
                <div class="d-flex justify-content-between mb-4 bg-light p-3 rounded-3 border">
                    <div class="text-center w-50 border-start">
                        <small class="text-muted d-block mb-1">الرصيد الدفتري (المتوقع)</small>
                        <h4 class="fw-bold text-primary m-0">@currentShift.ExpectedCash.ToString("N0") <small class="fs-6">ج.م</small></h4>
                    </div>
                    <div class="text-center w-50">
                        <small class="text-muted d-block mb-1">إجمالي المبيعات</small>
                        <h4 class="fw-bold text-success m-0">@currentShift.TotalAmounts.ToString("N0") <small class="fs-6">ج.م</small></h4>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-dark fs-5 mb-3">كم وجدت في الدرج فعلياً؟</label>
                    <div class="input-group input-group-lg shadow-sm">
                        <input type="number" 
                               class="form-control border-primary border-2 text-center fw-bold fs-3 shadow-none" 
                               placeholder="0.00"
                               @bind="actualCash" @bind:event="oninput">
                        <span class="input-group-text bg-primary text-white border-primary fw-bold">ج.م</span>
                    </div>
                </div>

                @{
                    decimal expected = currentShift.ExpectedCash; // ده اللي جاي من حساباتك
                    decimal difference = actualCash - expected;
                }

                @if (actualCash > 0)
                {
                    <div class="alert @(difference == 0 ? "alert-success" : (difference < 0 ? "alert-danger" : "alert-warning")) border-0 shadow-sm animate__animated animate__fadeIn">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">
                                @(difference == 0 ? "الخزينة متطابقة" : (difference < 0 ? "يوجد عجز بقيمة" : "يوجد زيادة بقيمة"))
                            </span>
                            <span class="fs-4 fw-bold">@Math.Abs(difference).ToString("N0") ج.م</span>
                        </div>
                    </div>
                }

            </div>

            <div class="modal-footer border-0 p-4 pt-0">
                <button class="btn btn-outline-primary w-100 py-3 fw-bold rounded-3 shadow-sm border-0 fs-5" 
                        disabled="@(actualCash <= 0)"
                        @onclick="ConfirmClose">
                    تأكيد الجرد وإغلاق الوردية <i class="bi bi-check2-all ms-2"></i>
                </button>
                <button class="btn btn-link w-100 text-muted text-decoration-none mt-2" @onclick="CloseModal">
                    تراجع، لم أنتهِ بعد
                </button>
            </div>
        </div>
    </div>
</div>
}
@if (currentShift == null )
{
    
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 400px;">
        <div class="card shadow-lg border-0 text-center p-5" style="max-width: 500px; border-radius: 20px; direction: rtl;">
            <div class="card-body">
                <div class="mb-4">
                    <i class="bi bi-door-open-fill text-secondary opacity-25" style="font-size: 5rem;"></i>
                </div>
            
                <h3 class="fw-bold text-dark mb-3">لا توجد وردية مفتوحة حالياً</h3>
                <p class="text-muted mb-4">
                    عشان تقدر تبدأ تبيع وتسجل مبيعات أو مصاريف، لازم تفتح وردية جديدة وتحدد مبلغ العهدة (الدرج).
                </p>

                <a href="/open-shift" class="btn btn-primary btn-lg w-100 py-3 fw-bold shadow-sm" style="border-radius: 12px;">
                    <i class="bi bi-plus-circle-fill ms-2"></i> فتح وردية جديدة الآن
                </a>
            </div>
        </div>
    </div>

}

else
{
        @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 small rounded-3 mb-3 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-3"></i>
    
            <div class="flex-grow-1">
                &nbsp;@errorMessage
            </div>
        </div>
    }
    <div class="container-fluid shift-page p-2"
         style="direction: rtl; text-align: right; background-color: #f4f7f6;">

        <div class="d-flex justify-content-between align-items-center mb-3 px-2 flex-wrap gap-2">
            <div>
                <h4 class="fw-bold m-0 text-dark">
                    إدارة الوردية <span class="text-primary"></span>
                </h4>
            </div>

            <button @onclick="()=> closeShiftModel = true" class="btn btn-warning fw-bold px-4 shadow-sm border-2 rounded-pill">
                إنهاء الوردية
            </button>
        </div>

        <div class="row g-2 mb-3 px-1">

            <div class="col-6 col-lg">
                <div class="card border-0 shadow-sm p-3 h-100 rounded-4 border-start border-primary border-5">
                    <small class="text-muted fw-bold">الافتتاح</small>
                    <div class="fw-bold fs-4">@currentShift.InitialCash.ToString("N0") ج.م</div>
                </div>
            </div>
            @foreach (var pay in currentShift.PaymentMethods)
            {
                <div class="col-6 col-lg">
                    <div class="card border-0 shadow-sm p-3 h-100 rounded-4 border-start border-success border-5">
                        <small class="text-muted fw-bold">@pay.Name</small>
                        <div class="fw-bold fs-4 text-success">@pay.TotalAmount.ToString("N0") ج.م</div>
                    </div>
                </div>
            }
            <div class="col-6 col-lg">
                <div class="card border-0 shadow-sm p-3 h-100 rounded-4 bg-dark text-white">
                    <small class="text-warning fw-bold small">الصافي المتوقع (كاش)</small>
                    <div class="fw-bold fs-4 text-warning">@currentShift.ExpectedCash.ToString("N0") ج.م</div>
                </div>
            </div>

        </div>

        <div class="row g-2 px-1">

            <div class="col-lg-4 d-flex flex-column gap-3">

                <EditForm Model="expenseModel" OnValidSubmit="HandleExpense">
                    <DataAnnotationsValidator></DataAnnotationsValidator>

                    <div class="card shadow-sm border-0 rounded-4 border-top border-danger border-4">
                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-3 text-danger"><i class="bi bi-cash-stack me-1"></i> تسجيل مصروف</h6>
                            <div class="input-group input-group-sm mb-2">
                                <InputNumber @bind-Value="expenseModel.Amount" class="form-control shadow-none" placeholder="المبلغ" />
                                <ValidationMessage For="@(() => expenseModel.Amount)" class="text-danger small" />

                                <InputText @bind-Value="expenseModel.Description" class="form-control w-50 shadow-none" placeholder="البيان..." />
                                <ValidationMessage For="@(() => expenseModel.Description)" class="text-danger small" />

                            </div>
                    
                            @if (expenseModel.Amount > currentShift.ExpectedCash)
                            {
                                <div class="text-danger extra-small mb-2"><i class="bi bi-exclamation-triangle"></i> المبلغ يتجاوز المتاح بالدرج!</div>
                            }
                    
                            <button type="submit"
                                    class="btn btn-danger btn-sm w-100 fw-bold rounded-3"
                                    disabled="@(expenseModel.Amount <= 0 || expenseModel.Amount > currentShift.ExpectedCash)">
                                تأكيد المصروف
                            </button>
                        </div>
                    </div>
                </EditForm>

                <EditForm Model="adjModel" OnValidSubmit="HandleAdjustment">
                    <DataAnnotationsValidator></DataAnnotationsValidator>
                    <div class="card shadow-sm border-0 rounded-4 border-top border-warning border-4">
                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-3 text-warning"><i class="bi bi-arrow-left-right me-1 text-dark"></i> تسوية رصيد</h6>
                    
                            <div class="input-group input-group-sm mb-2">
                                <InputSelect @bind-Value="adjModel.AdjustmentDirection" class="form-select fw-bold border-warning border-opacity-50 shadow-none" style="max-width: 100px;">
                                    <option value="in">إيداع (+)</option>
                                    <option value="out">سحب (-)</option>
                                </InputSelect>
                                <InputNumber @bind-Value="adjModel.Amount" class="form-control border-warning border-opacity-50 shadow-none" placeholder="المبلغ" />
                                <ValidationMessage For="@(() => adjModel.Amount)" class="text-danger small" />

                            </div>
                            <InputText @bind-Value="adjModel.Description" class="form-control form-control-sm bg-light border-0 mb-3 shadow-none" placeholder="ملاحظات التسوية..." />
                            <ValidationMessage For="@(() => adjModel.Description)" class="text-danger small" />

                            @{
                                bool isOverLimit = adjModel.AdjustmentDirection == "out" && adjModel.Amount > currentShift.ExpectedCash;
                            }

                            @if (isOverLimit)
                            {
                                <div class="text-danger extra-small mb-2"><i class="bi bi-exclamation-triangle"></i> لا توجد سيولة كافية للسحب!</div>
                            }

                            <button type="submit"
                                    class="btn btn-warning btn-sm w-100 fw-bold rounded-3 text-dark"
                                    disabled="@(adjModel.Amount <= 0 || isOverLimit)">
                                تنفيذ التسوية
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>


            <div class="col-lg-8">

                <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100">

                    <div class="card-header bg-white py-2 border-0">
                        <h6 class="fw-bold m-0 small">
                            سجل حركات الخزينة
                        </h6>
                    </div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-header bg-white py-3 border-0">
        <h6 class="fw-bold m-0 text-dark"><i class="bi bi-journal-text me-2"></i> سجل حركات الوردية </h6>
    </div>
    
    <div class="table-container">
        <table class="table table-hover align-middle mb-0 text-center custom-table">
            <thead>
                <tr>
                    <th class="col-type">النوع</th>
                    <th class="col-desc text-start">البيان</th>
                    <th class="col-user">بواسطة</th>
                    <th class="col-time">الوقت</th>
                    <th class="col-amount">المبلغ</th>
                </tr>
            </thead>
            <tbody class="small">
                @foreach (var item in transactions)
                {
                    <tr>
                        <td>
                            @{
                                var badgeClass = item.Type switch {
                                    TransactionType.OpeningBalance => "badge-opening",
                                    TransactionType.Sale => "badge-sale",
                                    TransactionType.Expense => "badge-expense",
                                    TransactionType.Return => "badge-return",
                                    _ => "badge-adj"
                                };
                                var typeName = item.Type switch {
                                    TransactionType.OpeningBalance => "افتتاح",
                                    TransactionType.Sale => "بيع كاش",
                                    TransactionType.Expense => "مصروف",
                                    TransactionType.Return => "مرتجع",
                                    _ => "تسوية"
                                };
                            }
                            <span class="badge rounded-pill @badgeClass w-100">@typeName</span>
                        </td>

                        <td class="text-start">
                            <span class="text-truncate d-block" title="@item.Description">
                                @item.Description
                            </span>
                        </td>

                        <td>
                            <div class="d-flex align-items-center justify-content-center">
            
                                <span style="font-size: 0.75rem;">@item.CreatedBy</span>
                            </div>
                        </td>

                        <td class="text-muted" style="font-size: 0.75rem;">
                            @item.CreatedAt.ToString("hh:mm tt")
                        </td>

                        <td class="fw-bold @(item.Amount >= 0 ? "text-success" : "text-danger")">
                            @item.Amount.ToString("N0")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
                </div>

            </div>

        </div>

    </div>

}



<style>

    html,
    body {
        overflow-x: hidden;
    }

    .shift-page {
        overflow-x: hidden;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .bg-warning-subtle {
        background-color: #fff9db !important;
    }

    .bg-danger-subtle {
        background-color: #fff5f5 !important;
    }

    .bg-success-subtle {
        background-color: #ebfbee !important;
    }

    .btn-check:checked + .btn-outline-success {
        background-color: #198754;
        color: white;
    }

    .btn-check:checked + .btn-outline-danger {
        background-color: #dc3545;
        color: white;
    }

    .table-wrapper {
        width: 100%;
        overflow-x: hidden;
    }


    .table-container {
        height: 400px; 
        overflow-y: auto;
        border-radius: 8px;
        background: #fff;
    }

    .custom-table {
        table-layout: fixed;
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    /* تحديد عرض الأعمدة */
    .col-type { width: 110px; }
    .col-desc { width: auto; }
    .col-user { width: 100px; }
    .col-time { width: 90px; }
    .col-amount { width: 100px; }

    /* تثبيت الهيدر */
    .custom-table thead th {
        position: sticky;
        top: 0;
        background-color: #f8f9fa;
        z-index: 10;
        border-bottom: 2px solid #dee2e6;
        font-size: 0.85rem;
        color: #6c757d;
    }

    /* تنسيق الأفاتار الصغير */
    .user-avatar {
        width: 24px;
        height: 24px;
        font-size: 0.7rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: #e9ecef;
        border-radius: 50%;
        font-weight: bold;
        margin-left: 5px;
    }

    /* ألوان الحالات (Badges) */
    .badge-opening { background-color: #e7f5ff; color: #0d6efd; border: 1px solid #cfe2ff; }
    .badge-sale { background-color: #ebfbee; color: #198754; border: 1px solid #d1e7dd; }
    .badge-expense { background-color: #fff5f5; color: #dc3545; border: 1px solid #f8d7da; }
    .badge-return { background-color: #fff4e6; color: #fd7e14; border: 1px solid #ffe8cc; }
    .badge-adj { background-color: #fff9db; color: #856404; border: 1px solid #ffeeba; }

    .text-truncate {
        max-width: 100%;
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* ستايل السكرول بار */
    .table-container::-webkit-scrollbar { width: 6px; }
    .table-container::-webkit-scrollbar-thumb { background: #ced4da; border-radius: 10px; }
</style>
@code 
{
    private ShiftDTO ? currentShift ;
    private IEnumerable <TransactionListDTO> transactions ; 
    private bool closeShiftModel = false ; 
    private decimal actualCash = 0 ; 

    private string ?errorMessage ; 
    protected override async Task OnInitializedAsync()
    {
        if (appState.CurrentShift == null)
        {
            nav.NavigateTo("/shift-decision");
            return;
        }
        await LoadData  () ; 
    }


    async Task LoadData ()
    {
        var result = await shiftService.GetOpenShiftAsync(); 
        if (result.IsSuccess)
        {
            currentShift = result.Data ; 
            var trancactionResult = await shiftService.GetAllShfitTransactions(currentShift.Id) ; 
            if  (trancactionResult.IsSuccess)
                transactions = trancactionResult.Data ; 
        }
    }
    private TransactionDTO expenseModel = new();
    private TransactionDTO adjModel = new();

    private async Task HandleExpense()
    {

        expenseModel.Type = TransactionType.Expense;
        expenseModel.Amount = expenseModel.Amount * -1 ; 
        var result = await shiftService.AddTransaction(currentShift!.Id , expenseModel);
        if (result.IsSuccess)
        {
            expenseModel = new(); 
            await LoadData();
        }
    }

    private async Task HandleAdjustment()
    {
        if (adjModel.AdjustmentDirection == "out")
            adjModel.Amount = -Math.Abs(adjModel.Amount);
        else
            adjModel.Amount = Math.Abs(adjModel.Amount);

        adjModel.Type = TransactionType.Adjustment ; 
        var result = await shiftService.AddTransaction(currentShift!.Id ,  adjModel);
        if (result.IsSuccess)
        {
            adjModel = new();
            adjModel.AdjustmentDirection = "in";
            await LoadData();
        }
    }
    private async Task ConfirmClose( )
    {
        closeShiftModel = false ; 
        var result =  await shiftService.CloseShift( currentShift.Id , actualCash) ; 
        if (!result.IsSuccess)
        {
            await ShowError(result.ErrorMessage) ; 
        }
        else
        {
            nav.NavigateTo("/") ; 
        }
    }
     private async Task ShowError(string ErrorMessage)
    {
        errorMessage = ErrorMessage;
        await Task.Delay(3000);
        errorMessage = null!;
    }
    private void CloseModal()
    {
        closeShiftModel = false ; 
    }
}