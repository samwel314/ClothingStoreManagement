@page "/shift-management"

<div class="container d-flex justify-content-center align-items-center" style="min-height: 400px;">
    <div class="card shadow-lg border-0 text-center p-5" style="max-width: 500px; border-radius: 20px; direction: rtl;">
        <div class="card-body">
            <div class="mb-4">
                <i class="bi bi-door-open-fill text-secondary opacity-25" style="font-size: 5rem;"></i>
            </div>
            
            <h3 class="fw-bold text-dark mb-3">لا توجد وردية مفتوحة حالياً</h3>
            <p class="text-muted mb-4">
                عشان تقدر تبدأ تبيع وتسجل مبيعات أو مصاريف، لازم تفتح وردية جديدة وتحدد مبلغ العهدة (الدرج).
            </p>

            <button class="btn btn-primary btn-lg w-100 py-3 fw-bold shadow-sm" style="border-radius: 12px;">
                <i class="bi bi-plus-circle-fill ms-2"></i> فتح وردية جديدة الآن
            </button>

            <div class="mt-3 small text-muted">
                <i class="bi bi-info-circle ms-1"></i> آخر وردية تم إغلاقها كانت: <span class="fw-bold">10:00 م | أمس</span>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid p-3" style="direction: rtl; text-align: right; background-color: #f8f9fa;">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0 text-dark">إدارة الوردية الحالية <small class="text-muted fs-6">(رقم #502)</small></h4>
            <p class="text-muted small mb-0">الموظف المسؤول: <b>أحمد مرزوق</b></p>
        </div>
        <div class="text-start">
            <span class="badge bg-white text-dark border p-2 shadow-sm mb-1">
                <i class="bi bi-calendar3 ms-1 text-primary"></i> 2024/05/20
            </span>
            <span class="badge bg-dark p-2 shadow-sm d-block">
                <i class="bi bi-clock-history ms-1 text-warning"></i> فُتحت منذ: 4 ساعات و 10 دقائق
            </span>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-right: 5px solid #0d6efd !important;">
                <small class="text-muted">رصيد بداية الوردية</small>
                <h3 class="fw-bold m-0">500.00 <small class="fs-6 text-secondary">ج.م</small></h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-right: 5px solid #198754 !important;">
                <small class="text-muted">صافي مبيعات (كاش)</small>
                <h3 class="fw-bold text-success m-0">+2,450.00</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm p-3 h-100" style="border-right: 5px solid #6f42c1 !important;">
                <small class="text-muted">مبيعات (فيزا / محفظة)</small>
                <h3 class="fw-bold text-purple m-0" style="color: #6f42c1;">1,200.00</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-dark text-white p-3 h-100">
                <small class="text-light opacity-75">المتوقع فعلياً بالدرج</small>
                <h3 class="fw-bold text-warning m-0">2,830.00 <small class="fs-6 text-white">ج.م</small></h3>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white fw-bold py-3">
                    <i class="bi bi-patch-minus me-2"></i> سحب مبلغ من الدرج (مصروف)
                </div>
                <div class="card-body">
                    <div class="alert alert-warning py-2 small">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i> سيتم خصم هذا المبلغ من "الرصيد المتوقع" فوراً.
                    </div>
                    <form>
                        <div class="mb-3">
                            <label class="form-label fw-bold">المبلغ المسحوب</label>
                            <div class="input-group">
                                <input type="number" class="form-control form-control-lg border-danger" placeholder="0.00">
                                <span class="input-group-text bg-danger text-white">ج.م</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">نوع المصروف</label>
                            <select class="form-select">
                                <option>نثريات</option>
                                <option>رواتب وسلف</option>
                                <option>مرتجع مشتريات</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger w-100 py-2 fw-bold shadow-sm">
                            تأكيد السحب والطباعة <i class="bi bi-printer ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <span class="fw-bold text-primary"><i class="bi bi-list-ul me-2"></i> آخر حركات الوردية</span>
                    <button class="btn btn-warning fw-bold px-4 shadow-sm border-2">
                        <i class="bi bi-door-closed-fill"></i> إنهاء وجرد الوردية
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <div class="table-responsive shadow-sm rounded border">
                            <div class="table-responsive shadow-sm rounded border">
                                <table class="table table-hover align-middle mb-0 text-center" style="direction: rtl;">
                                    <thead class="table-dark">
                                        <tr>
                                            <th style="width: 15%;">العملية</th>
                                            <th style="width: 45%;">البيان (الوصف)</th>
                                            <th style="width: 20%;">الوقت</th>
                                            <th style="width: 20%;">المبلغ</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><span class="badge bg-success w-100 p-2">بيع كاش</span></td>
                                            <td class="text-start pe-3">فاتورة مبيعات رقم <span class="fw-bold">#1025</span></td>
                                            <td class="text-muted small">11:30 ص</td>
                                            <td class="fw-bold text-success">+850.00</td>
                                        </tr>

                                        <tr>
                                            <td><span class="badge bg-danger w-100 p-2">مصروف</span></td>
                                            <td class="text-start pe-3 text-truncate" style="max-width: 200px;">نثريات - <span class="text-muted">شراء أدوات نظافة للمحل</span></td>
                                            <td class="text-muted small">01:15 م</td>
                                            <td class="fw-bold text-danger">-120.00</td>
                                        </tr>

                                        <tr>
                                            <td><span class="badge bg-primary w-100 p-2">بيع فيزا</span></td>
                                            <td class="text-start pe-3">فاتورة مبيعات رقم <span class="fw-bold">#1026</span></td>
                                            <td class="text-muted small">02:00 م</td>
                                            <td class="fw-bold text-primary">+1,200.00</td>
                                        </tr>

                                        <tr>
                                            <td><span class="badge bg-warning text-dark w-100 p-2">مرتجع</span></td>
                                            <td class="text-start pe-3 text-danger">إرجاع تيشيرت - <span class="small">فاتورة #1010</span></td>
                                            <td class="text-muted small">03:30 م</td>
                                            <td class="fw-bold text-danger">-100.00</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
