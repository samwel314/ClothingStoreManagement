@page "/open-shift"
@inject NavigationManager Nav
@inject AppState AppState
@inject ShiftService ShiftService
<div class="d-flex align-items-center justify-content-center" dir="rtl"
     style="background-color: #f4f7f9; overflow: hidden; font-family: sans-serif;">
    
    <div class="row g-0 shadow-sm border-0"
         style="width: 850px; height: 480px; background: white; border-radius: 20px; overflow: hidden;">
        
        <div class="col-5 d-flex flex-column justify-content-between p-5"
             style="background-color: #2c3e50; color: #ecf0f1;">
            
            <div>
                <div class="mb-4 opacity-75">
                    <i class="bi bi-person-badge fs-1"></i>
                </div>
                <h3 class="fw-normal mb-1">مرحباً بك</h3>
                <h2 class="fw-bold text-white">@AppState.CurrentUser?.UserName</h2>
                <div class="badge bg-light text-dark mt-2 fw-normal px-3 py-2 rounded-pill shadow-sm">
                    المسؤول الحالي
                </div>
            </div>

        </div>

        <div class="col-7 d-flex flex-column justify-content-center p-5 bg-white">
            <div class="text-end mb-4">
                <h4 class="fw-bold mb-1 text-dark">فتح الوردية</h4>
                <p class="text-muted small">يرجى تسجيل عهدة البداية لبدء العمليات</p>
            </div>

            <EditForm Model="shift" OnValidSubmit="StartShift">
                <DataAnnotationsValidator />
                <div class="mb-4">
                    <div class="p-3 rounded-4" style="background-color: #f8fafc; border: 1px solid #e2e8f0;">
                        <label class="d-block text-muted small mb-2 text-end">المبلغ النقدي بالدرج (EGP)</label>
            
                        <InputNumber @bind-Value="shift.InitialCash"
                                     class="form-control border-0 bg-transparent fs-1 fw-bold text-center"
                                     placeholder="0.00"
                                     style="outline: none; box-shadow: none; color: #1e293b;" />
            
                        <ValidationMessage For="@(() => shift.InitialCash)" class="text-danger small mt-1 text-end" />
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-lg py-3 rounded-3 fw-bold border-0 text-white shadow-sm"
                            style="background-color: #34495e; transition: 0.3s;">
                        تأكيد وفتح الوردية
                    </button>
        
                    <a href="/" class="btn btn-link btn-sm text-decoration-none text-muted mt-2" >
                        إلغاء العملية
                    </a>
                </div>
            </EditForm>

            <div class="mt-4 pt-3 border-top text-center">
                <span class="text-muted" style="font-size: 0.75rem;">
                    <i class="bi bi-info-circle ms-1"></i>
                    سيتم ترحيل هذا المبلغ كعهدة افتتاحية لوردية اليوم
                </span>
            </div>
        </div>

    </div>
</div>
@code
{
    private CreateShiftDTO shift = new CreateShiftDTO(); 
    private string? error;  

    private async Task StartShift()
    {
        var result = await ShiftService.CreateShiftAsync(shift);

        if (result.IsSuccess)
        {
            AppState.SetCurrentShift(result.Data!);
            Nav.NavigateTo("/pos");
        }
        else
        {
            error = result.ErrorMessage;
        }
    }
}