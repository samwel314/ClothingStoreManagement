@page "/dashboard"
@inject InvoiceService invoiceService
@if (confirmingReturn)
{
    <div class="modal fade show" id="returnModal" tabindex="-1" style="display: block; background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">تأكيد عملية المرتجع ⚠️</h5>
                </div>
                <div class="modal-body text-center py-4">
                    <p class="fs-5">هل أنت متأكد من إرجاع الفاتورة رقم <span class="badge bg-dark">#@invoiceToReturnSerial</span>   ؟ </p>
                    <p class="text-secondary mb-0">بمجرد التأكيد، ستعود الكميات للمخزن وتتحول الفاتورة لحالة مرتجع.</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="() => confirmingReturn = false">إلغاء</button>
                    <button type="button" class="btn btn-outline-danger px-4" @onclick="ExecuteReturn">تأكيد وإرجاع الكل</button>
                </div>
            </div>
        </div>
    </div>
}
@if (isModalVisible && selectedInvoice != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                
                <div class="modal-header @(selectedInvoice.Status == InvoiceStatus.completed ? "bg-success" : "bg-danger") text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-receipt"></i> تفاصيل فاتورة : @selectedInvoice.SerialNumber
                    </h5>
                </div>

                <div class="modal-body">
                    <div class="row mb-3 text-end" dir="rtl">
                        <div class="col-6">
                            <strong>حالة الفاتورة:</strong>
                            <span class="badge @(selectedInvoice.Status == InvoiceStatus.completed ? "bg-success" : "bg-danger")">
                                @(selectedInvoice.Status == InvoiceStatus.completed ? "مكتملة ✅" : "مرتجعة 🔄")
                            </span>
                        </div>
                        <div class="col-6">
                            <strong> تاريخ التحديث : </strong> 
                            <span class="text-secondary">@selectedInvoice.LastUpdate.ToString("dd/MM/yyyy")</span>
                            <span class="mx-1 text-muted">|</span>
                            <span class="fw-bold">@selectedInvoice.LastUpdate.ToString("hh:mm tt")</span>
                        </div>
                    </div>

                    <div class="table-responsive" dir="rtl">
                        <table class="table table-hover text-center align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>المنتج</th>
                                    <th>اللون/المقاس</th>
                                    <th>السعر</th>
                                    <th>الكمية</th>
                                    <th>المتاح حالياً</th>
                                    <th>الخصم</th>
                                    <th>الإجمالي</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in selectedInvoice.Items)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.ProductName</td>
                                        <td>
                                            <span class="badge bg-light text-dark border">@item.Color</span>
                                            <span class="badge bg-secondary">@item.Size</span>
                                        </td>
                                        <td>@item.Price.ToString("N2")</td>
                                        <td><span class="fw-bold">@item.Quantity</span></td>
                                        <td>
                                            <span class="@(item.AvailableQuantity < item.Quantity ? "text-danger fw-bold" : "text-muted")">
                                                @item.AvailableQuantity
                                                @if (item.AvailableQuantity < item.Quantity)
                                                {
                                                    <i class="bi bi-exclamation-triangle-fill small"></i>
                                                }
                                            </span>
                                        </td>
                                        <td class="text-danger">% @item.Discount.ToString("N2")</td>
                                        <td class="table-primary fw-bold">
                                        
                                            @{
                                                var subTotal = item.Quantity * item.Price;
                                                var discountAmount = subTotal * (item.Discount / 100);
                                                var finalItemTotal = subTotal - discountAmount;
                                            }
                                            @finalItemTotal.ToString("N2")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

             
                    <div class="card bg-light border-0 mt-3" dir="rtl">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span> إجمالي الفاتورة : </span>
                                <span>@selectedInvoice.TotalAmount.ToString("N2") ج.م</span>
                            </div>
                            <div class="d-flex justify-content-between text-danger mb-2">
                                <span>إجمالي الخصومات : </span>
                                <span>- @((selectedInvoice.TotalAmount - selectedInvoice.TotalAmountWithDiscount).ToString("N2")) ج.م</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between fw-bold fs-5 text-primary">
                                <span>الصافي النهائي : </span>
                                <span>@selectedInvoice.TotalAmountWithDiscount.ToString("N2") ج.م</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary" @onclick="CloseModal">إغلاق</button>
                    @if (selectedInvoice.Status == InvoiceStatus.completed)
                    {
                        <button class="btn btn-primary">
                        <i class="bi bi-printer"></i> طباعة الفاتورة
                    </button>
                    }
        
                </div>
            </div>
        </div>
    </div>
}

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 small rounded-3 mb-3 d-flex align-items-center" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-3"></i>
    
            <div class="flex-grow-1">
                &nbsp;@errorMessage
            </div>
        </div>
    }
      
    
<div class="card border-0 shadow-sm rounded-4 mb-4 bg-white overflow-hidden" dir="rtl">

    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-primary bg-opacity-10 p-2 rounded-3">
                <i class="bi bi-receipt text-primary fs-4"></i>
            </div>
            <div>
                <h5 class="fw-bold mb-0 text-dark">إدارة الفواتير</h5>
                <p class="text-muted small mb-0">فلترة ومراجعة سجل العمليات</p>
            </div>
        </div>
        <a href="/pos" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i>
            <span>فاتورة جديدة</span>
        </a>
    </div>

    <div class="card-body p-4">

        <div class="row g-3 align-items-center">
            

            <div class="col-lg-4">
                <div class="input-group rounded-pill border bg-light p-1">
                    <span class="input-group-text bg-transparent border-0 text-muted">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"  class="form-control border-0 bg-transparent shadow-none"
                           placeholder="بحث برقم الفاتورة ..." @bind:event="oninput" @bind="searchTerm" @bind:after="ApplySearch" >
                </div>
            </div>

 
            <div class="col-lg-4">
                <div class="d-flex align-items-center gap-2 bg-light rounded-pill p-1 border">
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none" @bind="StartDate">
                    <span class="text-muted small">إلى</span>
                    <input type="date" class="form-control form-control-sm border-0 bg-transparent shadow-none" @bind="EndDate">
                </div>
            </div>

   
            <div class="col-lg-4">
                <div class="btn-group w-100 bg-light p-1 rounded-pill border" role="group">
                    <button @onclick='() => FilterByStatus(null)'
                            class="btn btn-sm rounded-pill border-0 fw-semibold @(status == null ? "btn-primary shadow-sm" : "text-muted")">
                        الكل
                    </button>
                    <button @onclick='() => FilterByStatus(InvoiceStatus.pending)'
                            class="btn btn-sm rounded-pill border-0 fw-semibold @(status == InvoiceStatus.pending ? "btn-warning shadow-sm" : "text-muted")">
                        مسودة
                    </button>
                    <button @onclick='() => FilterByStatus(InvoiceStatus.completed)'
                            class="btn btn-sm rounded-pill border-0 fw-semibold @(status == InvoiceStatus.completed ? "btn-success shadow-sm" : "text-muted")">
                        مدفوع
                    </button>
                    <button @onclick='() => FilterByStatus(InvoiceStatus.returned)'
                            class="btn btn-sm rounded-pill border-0 fw-semibold @(status == InvoiceStatus.returned ? "btn-danger shadow-sm" : "text-muted")">
                        مرتجع
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>



<style>
    /* تحسينات لجمالية المدخلات */
    .form-control:focus {
        background-color: transparent;
    }
    
    .btn-group .btn {
        transition: all 0.3s ease;
        font-size: 0.8rem;
        padding: 6px 12px;
    }

    /* لإخفاء أيقونة الكالندر الافتراضية وجعل الشكل أنضف */
    input[type="date"]::-webkit-inner-spin-button,
    input[type="date"]::-webkit-calendar-picker-indicator {
        opacity: 0.5;
        cursor: pointer;
    }
</style>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-center">
                <thead class="table-light">
                    <tr>
                        <th class="py-3">رقم الفاتورة</th>
                        <th class="py-3 text-start px-4">التاريخ والوقت</th>
                        <th class="py-3">الإجمالي</th>
                        <th class="py-3">الحالة</th>
                        <th class="py-3">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (invoices != null && invoices.Any())
                    {
                        foreach (var invoice in invoices)
                        {
                            <tr>
                                <td class="fw-bold text-primary">#@invoice.Serial</td>
                                <td class="text-start px-4 small">
                                    <div class="fw-bold text-dark">@invoice.LastUpdatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">@invoice.LastUpdatedAt.ToString("hh:mm tt")</div>
                                </td>
                                <td class="fw-bold">@invoice.TotalAmount.ToString("N0") ج.م</td>
                                <td>
                                    @if (invoice.Status == InvoiceStatus.completed)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                                            <i class="bi bi-check-circle-fill ms-1"></i> مدفوعة
                                        </span>
                                    }
                                    else if (invoice.Status == InvoiceStatus.returned)
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill">
                                            <i class="bi bi-arrow-counterclockwise ms-1"></i> مرتجع
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-dark border border-warning-subtle px-3 py-2 rounded-pill">
                                            <i class="bi bi-pencil-square ms-1"></i> مسودة
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group shadow-sm border rounded-pill bg-white px-1 overflow-hidden">
                                        @if (invoice.Status == InvoiceStatus.pending)
                                        {
                                            <a href="/pos/@invoice.Id.ToString()" class="btn btn-sm btn-white text-primary border-0" title="تكملة">
                                                <i class="bi bi-play-circle-fill fs-5"></i>
                                            </a>
                                            <button @onclick="() => Remove(invoice.Id)" class="btn btn-sm btn-white text-danger border-0" title="حذف">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button @onclick="() => OpenDetailsModal(invoice.Id)" class="btn btn-sm btn-white text-dark border-0" title="عرض التفاصيل">
                                                <i class="bi bi-eye-fill"></i>
                                            </button>
                                            @if (invoice.Status == InvoiceStatus.completed)
                                            {
                                                <button @onclick="() => ReturnInvoice(invoice.Id, invoice.Serial)" class="btn btn-sm btn-white text-danger border-0" title="عمل مرتجع">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            }
                                            @if (invoice.Status == InvoiceStatus.returned)
                                            {
                                                <a href="/pos/@invoice.Id.ToString()" class="btn btn-sm btn-white text-info border-0" title="تعديل">
                                                    <i class="bi bi-pencil-fill"></i>
                                                </a>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code
{
    private DateTime ? StartDate ; 
    private DateTime ? EndDate ;  
    private string? searchTerm;
    private InvoiceStatus ? status;
    private IEnumerable<InvoiceLockUpDTO>? invoices ;
    private int invoiceToReturnId ;
    private string invoiceToReturnSerial = string.Empty;    
    private bool confirmingReturn = false;
    private string? errorMessage;
    protected override async Task OnInitializedAsync()
    {
        await LoadInvoicesAsync();
    }
    private async Task LoadInvoicesAsync()
    {
        var result = await invoiceService.GetInvoicesLookUpAsync(searchTerm , status , StartDate , EndDate);
        invoices = result.Data!;
    }    

    public async Task FilterByStatus(InvoiceStatus ? status)
    {
        this.status = status;
        await LoadInvoicesAsync() ; 
    }
    private async Task ApplySearch()
    {
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            await LoadInvoicesAsync();
        }
    }

    private async Task Remove (int id )
    {
        await   invoiceService.Remove(id);  
        await LoadInvoicesAsync();
    }
    private InvoiceDTO? selectedInvoice;
    private bool isModalVisible = false;

    // دالة فتح الـ Modal وجلب البيانات
    private async Task OpenDetailsModal(int id)
    {
        var result = await invoiceService.GetInvoiceById(id);
        if (result.IsSuccess)
        {
            selectedInvoice = result.Data;
            isModalVisible = true;        }
        else
        {
            await ShowError(result.ErrorMessage!);
        }
    }

    private void CloseModal()
    {
        isModalVisible = false;
        selectedInvoice = null;
    }

    private void ReturnInvoice(int id, string serial)
    {
        invoiceToReturnId = id;
        invoiceToReturnSerial = serial;
        confirmingReturn = true;
    }
    private async Task ExecuteReturn()
    {
        confirmingReturn = false;
        var result = await invoiceService.ReturnInvoice(invoiceToReturnId);
        if (result.IsSuccess)
        {
            await LoadInvoicesAsync();
        }
        else
        {
            await ShowError(result.ErrorMessage!);
        }
    }   
    private async Task ShowError(string ErrorMessage)
    {
        errorMessage = ErrorMessage;
        await Task.Delay(3000);
        errorMessage = null!;
    }
}
