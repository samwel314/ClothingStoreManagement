@page "/payment-sources"
@inject PaymentSourceService PaymentService
@inject AppState AppState

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show border-0 small rounded-3 mb-3 d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-3"></i>
        <div class="flex-grow-1">@errorMessage</div>
        <button type="button" class="btn-close ms-0 me-auto" @onclick="() => errorMessage = null"></button>
    </div>
}

<div class="row align-items-center mb-4 g-4" dir="rtl">
    <div class="col-lg-4 text-start">
        <div class="d-flex align-items-center justify-content-end">
            <div class="ms-4 text-end">
                <h3 class="fw-bold mb-0 text-dark">وسائل الدفع</h3>
                <p class="text-muted small mb-0">إدارة الخزائن والمحافظ الإلكترونية</p>
            </div>
            <div class="bg-primary bg-opacity-10 p-3 rounded-3 shadow-sm">
                <i class="bi bi-wallet2 text-primary fs-4"></i>
            </div>
        </div>
    </div>

    @if (AppState.CurrentUser?.Role == UserRole.Admin)
    {
        <div class="col-lg-3 text-start">
            <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm d-inline-flex align-items-center gap-2"
                    @onclick="OpenAddModal">
                <i class="bi bi-plus-circle fs-5"></i>
                <span>وسيلة جديدة</span>
            </button>
        </div>
    }
</div>


<div class="card shadow-sm border-0 mt-3" dir="rtl">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-primary text-white">
                <tr>
                    <th class="py-3 ps-4">الاسم</th>
                    <th class="py-3 text-center">الحالة</th>
                    <th class="py-3 text-center">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (allSources != null && allSources.Any())
                {
                    @foreach (var source in allSources)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@source.Name</td>
                            <td class="text-center">
                                <span class="badge @(source.IsActive ? "bg-success" : "bg-danger")">
                                    @(source.IsActive ? "نشط" : "معطل")
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-outline-primary btn-sm border-0" @onclick="() => OpenEditModal(source)">
                                        <i class="bi bi-pencil-square fs-5"></i>
                                    </button>
                                    <button class="btn btn-sm @(source.IsActive ? "btn-outline-danger" : "btn-outline-success") border-0"
                                            @onclick="() => ToggleStatus(source.Id)">
                                        <i class="bi @(source.IsActive ? "bi-slash-circle" : "bi-check-circle") fs-5"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted small">لا توجد بيانات لعرضها</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (isModalOpen)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 text-end" dir="rtl">
                <EditForm Model="sourceModel" OnValidSubmit="HandleSaveSource">
                    <DataAnnotationsValidator />
                    <div class="modal-header border-0 pb-0">
                        <h5 class="fw-bold text-primary">
                            <i class="bi bi-wallet2 ms-2"></i>
                            @(isEditMode ? "تعديل وسيلة الدفع" : "إضافة وسيلة جديدة")
                        </h5>
                        <button type="button" class="btn-close ms-0 me-auto" @onclick="CloseModal"></button>
                    </div>

                    <div class="modal-body py-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">اسم الوسيلة (مثل: كاش، فيزا، فودافون كاش)</label>
                            <InputText @bind-Value="sourceModel.Name" class="form-control form-control-lg bg-light border-0" />
                            <ValidationMessage For="@(() => sourceModel.Name)" class="text-danger small mt-1" />
                        </div>
                    </div>

                    <div class="modal-footer border-0 pt-0">
                        <button type="submit" class="btn btn-primary px-5 rounded-3 fw-bold shadow-sm">حفظ</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<PaymentSourceDTO> allSources = new List<PaymentSourceDTO>();
    private CreateUpdatePaymentSourceDto sourceModel = new();
    private bool isModalOpen = false;
    private bool isEditMode = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var result = await PaymentService.GetActiveSourcesAsync();
        if (result.IsSuccess) allSources = result.Data!;
    }

    private void OpenAddModal()
    {
        sourceModel = new();
        isEditMode = false;
        isModalOpen = true;
    }

    private void OpenEditModal(PaymentSourceDTO source)
    {
        sourceModel = new CreateUpdatePaymentSourceDto { Id = source.Id, Name = source.Name };
        isEditMode = true;
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        errorMessage = null;
    }

    private async Task HandleSaveSource()
    {

        CloseModal();
        if (isEditMode)
        {
            var updateresult = await PaymentService.UpdatePaymentSourceAsync(sourceModel.Id!.Value, sourceModel);
            if (!updateresult.IsSuccess)
                  errorMessage = updateresult.ErrorMessage;
        }
        else
        {
            var createResult = await PaymentService.CreateSourceAsync(sourceModel.Name);
            if (!createResult.IsSuccess)     errorMessage = createResult.ErrorMessage;
        }

        await LoadData();
        StateHasChanged();
    }

    private async Task ToggleStatus(int id)
    {
        var result = await PaymentService.ToggleStatusAsync(id);
        if (!result.IsSuccess) errorMessage = result.ErrorMessage;
        await LoadData();
    }
}