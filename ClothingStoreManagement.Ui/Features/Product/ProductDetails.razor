@page "/product-details/{ProductId}"
@using ClothingStoreManagement.Ui.Features.Invoice
@inject ProductService productService 
@inject CategoryService categoryService
@inject ColorService colorService 
@inject SizeService sizeService 
@if (showMovements)
{
    <div class="position-fixed top-0 start-0 w-100 h-100" 
         style="z-index: 1050; background: rgba(0,0,0,0.15); backdrop-filter: blur(6px);" 
         @onclick="() => showMovements = false">
    </div>

    <div class="position-fixed top-0 start-0 h-100 bg-white shadow-lg border-end" 
         style="z-index: 1060; width: 520px; animation: slideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);">
        
        <div class="p-3 border-bottom bg-light shadow-sm">
            <div class="d-flex align-items-center mb-3">
                <div style="flex: 1;">
                    <button type="button" class="btn-close ms-2" @onclick="() => showMovements = false"></button>
                </div>
                <div style="flex: 2;" class="text-center">
                    <h6 class="fw-bold mb-0 text-dark" style="font-size: 1.1rem;">📦 @product.Name</h6>
                </div>
                <div style="flex: 1;"></div> </div>

            <div class="d-flex align-items-center justify-content-center gap-3 bg-white p-2 rounded-pill border mx-auto" style="font-size: 0.8rem; width: fit-content;">
                <span class="font-monospace text-muted">SKU: @selectedVariant.Sku</span>
                <span class="text-muted opacity-50">|</span>
                <span class="fw-bold text-dark">المقاس: @selectedVariant.Size</span>
                <span class="text-muted opacity-50">|</span>
                <div class="d-flex align-items-center gap-1">
                    <div style="width: 12px; height: 12px; background-color: @selectedVariant.Color; border-radius: 50%;" class="border"></div>
                    <span class="fw-bold text-secondary">اللون</span>
                </div>
            </div>
        </div>

        <div class="p-3 overflow-auto" style="height: calc(100vh - 125px); scrollbar-width: thin;">
            
            <div class="d-flex gap-2 mb-4">
                <div class="flex-fill p-2 rounded-3 bg-danger-subtle text-danger border-bottom border-danger border-3 text-center shadow-sm">
                    <small class="d-block fw-bold opacity-75" style="font-size: 0.65rem;">المبيعات</small>
                    <span class="fw-bold h6 mb-0">@MovementList.Where( m => m.Type == MovementType.Sale).Sum(m => m.QuantityChange)</span>
                </div>
                <div class="flex-fill p-2 rounded-3 bg-success-subtle text-success border-bottom border-success border-3 text-center shadow-sm">
                    <small class="d-block fw-bold opacity-75" style="font-size: 0.65rem;">المرتجع</small>
                    <span class="fw-bold h6 mb-0">+@MovementList.Where(m => m.Type == MovementType.Return).Sum(m => m.QuantityChange)</span>
                </div>
                <div class="flex-fill p-2 rounded-3 bg-primary-subtle text-primary border-bottom border-primary border-3 text-center shadow-sm">
                    <small class="d-block fw-bold opacity-75" style="font-size: 0.65rem;">الرصيد الحالي</small>
                    <span class="fw-bold h6 mb-0">@MovementList.OrderByDescending(m => m.CreatedAt).FirstOrDefault()?.StockAfter</span>
                </div>
            </div>

            <div class="table-responsive border-0 rounded-3 shadow-sm bg-white">
                <table class="table table-hover align-middle mb-0 text-center" style="font-size: 0.85rem;">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3 text-secondary fw-bolder border-0">الرصيد 📉</th>
                            <th class="py-3 text-secondary fw-bolder border-0">الكمية 📦</th>
                            <th class="py-3 text-secondary fw-bolder text-end pe-4 border-0">تفاصيل الحركة 📝</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var move in MovementList.OrderByDescending(m => m.CreatedAt))
                        {
                            <tr class="border-bottom border-light-subtle">
                                <td class="fw-bold text-dark fs-6">@move.StockAfter</td>
                                <td>
                                    <span class="badge @(move.QuantityChange > 0 ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-2 py-1 border fw-bold" style="min-width: 45px;">
                                        @(move.QuantityChange > 0 ? "+" : "")@move.QuantityChange
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="d-flex flex-column align-items-end py-2">
                                        <span class="fw-bold text-dark mb-1">@GetMovementTranslation(move.Type)</span>
                                        <div class="d-flex gap-2 align-items-center" style="font-size: 0.72rem;">
                                            @if (!string.IsNullOrEmpty(move.ReferenceId)) {
                                                <span class="badge bg-light text-primary border-0 fw-medium p-0">#@move.ReferenceId</span>
                                                <span class="text-muted opacity-50">|</span>
                                            }
                                            <span class="text-muted"><i class="bi bi-calendar3 me-1"></i> @move.CreatedAt.ToString("dd/MM/yyyy")</span>
                                            <span class="text-muted opacity-50">|</span>
                                            <span class="text-muted"><i class="bi bi-clock me-1"></i> @move.CreatedAt.ToString("hh:mm tt")</span>
                                        </div>
                                        @if (move.CreatedBy != null) {
                                            <small class="text-muted mt-1" style="font-size: 0.65rem; opacity: 0.8;">👤 @move.CreatedBy</small>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}


@if (showDeleteVariantConfirm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block animate-in fade-in" tabindex="-1" dir="rtl">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3 text-danger">
                        <i class="bi bi-exclamation-triangle-fill display-4"></i>
                    </div>
                    <h5 class="fw-bold mb-2">هل أنت متأكد؟</h5>
                    <p class="text-secondary small mb-4">
                        سيتم حذف هذا التنوع نهائياً من المخزون. لا يمكن التراجع عن هذا الإجراء.
                    </p>
                    
                    <div class="d-flex gap-2">
                        <button type="button" 
                                class="btn btn-danger w-100 rounded-pill py-2 fw-bold" 
                                @onclick="ConfirmDeleteVariant">
                            نعم، احذف
                        </button>
                        <button type="button" 
                                class="btn btn-light w-100 rounded-pill py-2 border" 
                                @onclick="() => showDeleteVariantConfirm = false">
                            إلغاء
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@if (showVariantModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" dir="rtl">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-light rounded-top-4">
                    <h5 class="modal-title fw-bold">
                        @(isEditVariantMode ? "تعديل نسخة المنتج" : "إضافة تنوع جديد ")
                   </h5>
                    <button type="button" class="btn-close ms-0 me-auto" @onclick="()=>showVariantModal=false "></button>
                </div>

                <EditForm Model="@variantModel" OnValidSubmit="SaveVariant">
                    <FluentValidationValidator />
                    
                    <div class="modal-body p-4">
                        <div class="row g-3">
                            @* اختيار اللون *@
                            <div class="col-md-6 text-end">
                                <label class="form-label fw-semibold">اللون</label>
                                <InputSelect @bind-Value="variantModel.ColorId" class="form-select shadow-sm">
                                    <option selected value="0">اختر اللون...</option>
                                    @if (Colors != null)
                                    {
                                        foreach(var c in Colors)
                                        {
                                            <option value="@c.Id">@c.Name</option>

                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => variantModel.ColorId)" class="text-danger small" />
                            </div>

                            @* اختيار المقاس *@
                            <div class="col-md-6 text-end">
                                <label class="form-label fw-semibold">المقاس</label>
                                <InputSelect @bind-Value="variantModel.SizeId" class="form-select shadow-sm">
                                    <option selected value="0">اختر المقاس...</option>
                                        @if (Sizes != null)
                                    {
                                        foreach(var c in Sizes)
                                        {
                                            <option value="@c.Id">@c.Name</option>

                                        }
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => variantModel.SizeId)" class="text-danger small" />
                            </div>

                            @* سعر الشراء *@
                            <div class="col-md-4 text-end">
                                <label class="form-label fw-semibold">سعر الشراء</label>
                                <div class="input-group">
                                    <InputNumber @bind-Value="variantModel.PurchasePrice" class="form-control" />
                                    <span class="input-group-text">ج.م</span>
                                </div>
                                <ValidationMessage For="@(() => variantModel.PurchasePrice)" class="text-danger small" />
                            </div>

                            @* سعر البيع *@
                            <div class="col-md-4 text-end">
                                <label class="form-label fw-semibold">سعر البيع</label>
                                <div class="input-group">
                                    <InputNumber @bind-Value="variantModel.SellingPrice" class="form-control" />
                                    <span class="input-group-text">ج.م</span>
                                </div>
                                <ValidationMessage For="@(() => variantModel.SellingPrice)" class="text-danger small" />
                            </div>

                            @* عدد القطع *@
                            <div class="col-md-4 text-end">
                                <label class="form-label fw-semibold">عدد القطع (المخزون)</label>
                                <InputNumber @bind-Value="variantModel.StockQuantity" class="form-control" />
                                <ValidationMessage For="@(() => variantModel.StockQuantity)" class="text-danger small" />
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer bg-light rounded-bottom-4">
                        <button type="submit" class="btn btn-primary px-5 rounded-pill shadow-sm fw-bold">
                            @(isEditVariantMode ? "حفظ التعديلات" : "إضافة النسخة")
                        </button>
                        <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" @onclick="()=> showVariantModal = false">إلغاء</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (OpenUpdateModel)
{
    <div class="update-modal-overlay" dir="rtl">
        <div class="card shadow-lg border-0 rounded-4 w-100 animate-slide-up" style="max-width: 450px; background: white;">
            <div class="card-header bg-primary text-white text-center py-4 rounded-top-4 position-relative">
                <div class="mb-2">
                    <i class="bi bi-pencil-square fs-1"></i>
                </div>
                <h3 class="fw-bold mb-0">تعديل البيانات</h3>
                <p class="small opacity-75">قم بتحديث اسم المنتج والصنف</p>
            </div>

            <div class="card-body p-4">
                <EditForm Model="@UpdateProduct" OnValidSubmit="SaveUpdateProduct">
                    <DataAnnotationsValidator />

                    <div class="mb-4">
                        <label for="name" class="form-label fw-bold text-secondary">
                            <i class="bi bi-tag-fill ms-1 text-primary"></i> اسم المنتج
                        </label>
                        <InputText id="name" @bind-Value="UpdateProduct.Name" class="form-control form-control-lg rounded-3 border-2" placeholder="مثلاً: قميص أبيض" />
                        <ValidationMessage For="@(() => UpdateProduct.Name)" class="text-danger small" />
                    </div>


                    <div class="mb-4">
                        <label for="category" class="form-label fw-bold text-secondary">
                            <i class="bi bi-grid-fill ms-1 text-primary"></i> الصنف
                        </label>
                        <InputSelect @bind-Value="UpdateProduct.CategoryId" class="form-select form-control-lg rounded-3 border-2">
                            <option value="">اختر الصنف...</option>
                            @if (Categories != null)
                            {
                                @foreach(var category in Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => UpdateProduct.CategoryId)" class="text-danger small" />
                    </div>

           
                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-primary btn-lg flex-grow-1 rounded-pill shadow-sm transition-btn">
                            <i class="bi bi-save2-fill ms-2"></i> حفظ التعديلات
                        </button>
                        <button type="button" @onclick="() => OpenUpdateModel = false" class="btn btn-light btn-lg rounded-pill border px-4">
                            إلغاء
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (OpneSkuForm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" dir="rtl">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 rounded-4">
                <div class="modal-header">
                    <h5 class="modal-title font-weight-bold">تحديث كود SKU</h5>
                    <button type="button" class="btn-close ms-0 me-auto" @onclick="() => OpneSkuForm = false"></button>
                </div>
                
                @* استخدام EditForm مع الموديل *@
                <EditForm Model="@skuModel" OnValidSubmit="SaveUpdateSku">
                    <DataAnnotationsValidator />
                    
                    <div class="modal-body">
                        <div class="mb-3 text-right">
                            <label class="form-label text-secondary">كود الـ SKU الجديد</label>
                            <InputText class="form-control form-control-lg bg-light" 
                                       @bind-Value="skuModel.SKU" 
                                       placeholder="أدخل الكود هنا..." />
                            <ValidationMessage For="@(() => skuModel.SKU)" class="text-danger small mt-1" />
                        </div>
                    </div>

                    <div class="modal-footer border-0">
                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                            <i class="bi bi-check-lg"></i> حفظ التغييرات
                        </button>
                        <button type="button" class="btn btn-link text-muted mt-2" @onclick="() => OpneSkuForm = false">
                            إلغاء
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (product != null )
{
