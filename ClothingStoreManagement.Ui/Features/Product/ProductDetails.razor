                            <th class="py-3 px-4 text-secondary small">اللون والمقاس</th>
                            <th class="py-3 text-secondary small">SKU / الباركود</th>
                            <th class="py-3 text-secondary small text-center">المخزون</th>
                                                        <th class="py-3 text-secondary small text-center">سعر الشراء </th>

                            <th class="py-3 text-secondary small text-center">السعر</th>
                            <th class="py-3 text-secondary small text-center">الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in product.Variants)
                        {
                            <tr>
                                <td class="px-4">
                                    <div class="d-flex align-items-center gap-2 flex-row-reverse justify-content-end">
                                        <span class="fw-bold text-dark">@v.Size</span>
                                        <div class="rounded-circle shadow-sm border" 
                                             style="width:18px; height:18px; background-color: @v.Color;"></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="font-monospace text-dark fw-semibold">@v.Sku</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="fw-bold @(v.StockQuantity <= 5 ? "text-danger" : "text-dark")">@v.StockQuantity</span>
                                    <small class="text-muted ms-1">قطعة</small>
                                </td>
                                       <td class="text-center">
                                    <span class="fw-bold text-danger">@v.Purchase.ToString("N0")</span>
                                    <small class="text-muted ms-1">ج.م</small>
                                </td>
                                <td class="text-center">
                                    <span class="fw-bold text-primary">@v.Price.ToString("N0")</span>
                                    <small class="text-muted ms-1">ج.م</small>
                                </td>
                                <td class="text-center">
                          <div class="d-flex justify-content-center gap-1">
    <button @onclick="() => ShowMovements(v)" class="btn btn-sm btn-light rounded-circle text-info border shadow-sm" title="سجل الحركة">
        <i class="bi bi-clock-history"></i>
    </button>

    <button @onclick="()=> UpdateVariant(v)" class="btn btn-sm btn-light rounded-circle text-primary border shadow-sm" title="تعديل">
        <i class="bi bi-pencil-square"></i>
    </button>

    <button @onclick="() => DeleteVariant(v)" class="btn btn-sm btn-light rounded-circle text-danger border shadow-sm" title="حذف">
        <i class="bi bi-trash3"></i>
    </button>
</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
        </div>
<div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <h5 class="fw-bold mb-3">🏆 الأكثر ربحية</h5>
            
              @if (product.TopVariant != null)

            {

                            <div class="mb-4 text-end">

    <div class="d-flex justify-content-between align-items-center mb-1">

        <div class="d-flex align-items-center">

            <span class="rounded-circle me-2 border" 

                  style="width: 15px; height: 15px; background-color: @product.TopVariant.Code; display: inline-block;">

            </span>

            <span class="fw-bold"> &nbsp;&nbsp; @product.TopVariant.Size </span>

        </div>

        

        <span class="text-primary fw-bold">

            @(product.NetProfit > 0 ? ((product.TopVariant.Total / product.NetProfit) * 100).ToString("0") : "0")%

        </span>

    </div>

    

    <div class="progress rounded-pill shadow-none" style="height: 10px;">

        <div class="progress-bar bg-primary" 

             style="width: @(product.NetProfit > 0 ? ((product.TopVariant.Total / product.NetProfit) * 100).ToString("0") : "0")%">

        </div>

    </div></div>



            }

       </div>
        </div>
    </div>
    </div>

}
else
{
    <div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="card shadow-sm border-0 rounded-4 text-center p-5" style="max-width: 550px; background-color: #fcfcfc;">
        <div class="card-body">
            <div class="mb-4 d-inline-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10" style="width: 100px; height: 100px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-box-seam text-warning" viewBox="0 0 16 16">
                    <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2l-2.218-.887zm3.564 1.426L5.596 5 8 5.961 14.154 3.5l-2.404-.961zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.722V6.828L1 4.24v7.922l6.5 2.6zM4.268 3.074a.5.5 0 0 1-.742-.596L4.545 1.32a.5.5 0 0 1 .742.596L4.268 3.074z"/>
                </svg>
            </div>
            <h3 class="fw-bold text-dark mb-2">عذراً.. هذا المنتج غير متاح</h3>
            <p class="text-muted mb-4 fs-6">
                يبدو أنك تحاول الوصول لمنتج غير موجود في قاعدة البيانات.
            </p>
        </div>
    </div>
</div>
}

<style>
    .rounded-4 { border-radius: 1.25rem !important; }
    .bg-success-subtle { background-color: #ecfdf5; }
    .hover-up { transition: transform 0.2s; cursor: default; }
    .hover-up:hover { transform: translateY(-5px); }
    .font-monospace { font-family: 'SFMono-Regular', Consolas, monospace; }

    /* Modal Overlay Styles */
    .update-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5); /* خلفية معتمة */
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999; /* لضمان الظهور فوق كل شيء */
        backdrop-filter: blur(4px); /* إضافة غبش خفيف للخلفية */
    }

    .animate-slide-up {
        animation: slideUp 0.3s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
        .rounded-4 { border-radius: 1rem !important; }
    .font-monospace { font-family: monospace; font-size: 1.1rem; }
    /* منع تداخل الـ CSS مع الـ Razor */
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

      .modal-content {
        animation: slideIn 0.3s ease-out;
    }

    @@keyframes slideIn {
        from { transform: translateY(-20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .form-select, .form-control {
        border-radius: 0.75rem;
        padding: 0.6rem 1rem;
    }

    .form-select:focus, .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    @@keyframes slideIn {
        from { transform: translateX(-100%); }
        to { transform: translateX(0); }
    }
    /* تحسين شكل الجدول ليكون بلا حدود خارجية */
    .table > :not(caption) > * > * {
        box-shadow: none !important;
        border-bottom-width: 1px;
    }
</style>

@code {
    [Parameter, SupplyParameterFromQuery] public string ProductId { get; set; }
    private ProductListDto product = null!;
    private bool showSuccess = false; 
    private UpdateProductBasicDto UpdateProduct = new UpdateProductBasicDto(); 
    private UpdateProductSkuDto skuModel = new () ; 
    private List<CategoryDTO> Categories = new();
    private List<ColorListDTO> Colors = new();
    private List<SizeListDTO> Sizes = new();
    private bool OpenUpdateModel = false;
    private bool OpneSkuForm = false ; 
    private string erroMessage = null! ; 
    private bool showVariantModal = false ; 
    private bool isEditVariantMode = false ; 
    private bool showDeleteVariantConfirm = false ; 
    private bool showMovements = false ; 
    private Guid VariantIdToDelete ; 
    private CreateProductVariantDto variantModel = new () ; 
    private ProductVariantListDto selectedVariant ; 
    private IEnumerable<VariantMovementsDTO> MovementList = new List<VariantMovementsDTO>() ;
    protected async override Task OnInitializedAsync()
    {
        var CategoriesResult = await categoryService.GetCategoriesLookUpAsync();
        if (CategoriesResult.IsSuccess)
            Categories = CategoriesResult.Data!.ToList();

        var ColorsResult = await colorService.GetColorsAsync();
        if (ColorsResult.IsSuccess)
            Colors = ColorsResult.Data!.ToList();

        var SizesResult = await sizeService.GetSizesAsync();
        if (SizesResult.IsSuccess)
            Sizes = SizesResult.Data!.ToList();
    }
    private async Task loadProduct ()
    {
        if (Guid.TryParse(ProductId, out Guid actualId))
        {
            var result = await productService.GetProductAsync(actualId); 
            if (result.IsSuccess)
                product = result.Data!; 
            else
                product = null!; 
            
        }

    }
    protected override async Task OnParametersSetAsync()
    {
        await loadProduct() ; 
    }

    private void UpdateModel()
    {
        OpenUpdateModel = true;
        UpdateProduct.CategoryId = product.CategoryId;
        UpdateProduct.Name = product.Name; 
        UpdateProduct.ProductId = product.Id; 
    }

    private void UpdateSku()
    {
        OpneSkuForm = true;
        skuModel.ProductId = product.Id;
        skuModel.SKU = product.SKU; 
    }
    private async Task SaveUpdateProduct()
    {
        var result = await productService.UpdateProductBasicAsync(UpdateProduct) ; 
        if(result.IsSuccess)
        {
            showSuccess = true ;
            OpenUpdateModel = false ; 


            await loadProduct() ; 
            await  Task.Delay(3000) ; 
            showSuccess = false ;
        }
        else
        {
            erroMessage = result.ErrorMessage! ; 
            OpenUpdateModel = false ; 
            await  Task.Delay(3000) ; 
            erroMessage = null! ; 
        }
    }
    private async Task  SaveUpdateSku()
    {
        var result = await productService.UpdateProductSkuAsync(skuModel) ; 

        if(result.IsSuccess)
        {
            showSuccess = true ;
            OpneSkuForm = false ; 
            await loadProduct() ; 
            await  Task.Delay(3000) ; 
            showSuccess = false ;
        }
        else
        {
            erroMessage = result.ErrorMessage! ; 
            OpneSkuForm = false ; 
            await  Task.Delay(3000) ; 
            erroMessage = null! ; 
        }


    }
    private void AddVariant ()
    {
        variantModel = new()
        {
            ProductId = product.Id
        } ; 
        isEditVariantMode = false ; 
        showVariantModal = true ; 
    }
    private void UpdateVariant(ProductVariantListDto model)
    {
        showVariantModal = true ; 
        isEditVariantMode = true ; 
        variantModel.ProductId = product.Id ; 
        variantModel.Id = model.Id ; 
        variantModel.StockQuantity = model.StockQuantity ; 
        variantModel.SellingPrice = model.Price ; 
        variantModel.PurchasePrice = model.Purchase ; 
        variantModel.StockQuantity = model.StockQuantity ; 
        variantModel.ColorId = model.ColorId ; 
        variantModel.SizeId = model.SizeId ; 
    }

    private async Task SaveVariant()
    {
        showVariantModal = false ; 

        Result<string> result ; 
        if (isEditVariantMode)
        {
            result =   await productService.UpdateVariantAsync(variantModel) ; 
        }
        else
        {
            result =   await productService.CreateVariantAsync(variantModel) ; 

        }
        if (result.IsSuccess)
        {
            showSuccess = true ; 
            await loadProduct() ; 

            await  Task.Delay(3000) ; 
            showSuccess = false ; 
        }
        else
        {
            erroMessage = result.ErrorMessage! ;         
            await  Task.Delay(3000) ; 
            erroMessage = null! ; 

        }

    }
    void DeleteVariant (ProductVariantListDto model)
    {
        VariantIdToDelete = model.Id ; 
        showDeleteVariantConfirm = true  ; 
    }

    async Task ConfirmDeleteVariant ()
    {
        var result =  await  productService.DeleteVariant(VariantIdToDelete) ; 
        showDeleteVariantConfirm = false ; 
        if  (result.IsSuccess)
        {
            showSuccess = true ; 
            await loadProduct() ; 

            await  Task.Delay(3000) ; 
            showSuccess = false ; 
        }
        else
        {
            erroMessage = result.ErrorMessage! ;         
            await  Task.Delay(3000) ; 
            erroMessage = null !; 
        }
    }
    private string GetMovementTranslation(MovementType type)
    {
        return type switch
        {
            MovementType.Sale => "عملية بيع مبيعات",    
            MovementType.Return => "مرتجع من فاتورة",
            MovementType.Restock => "توريد مخزني جديد",  
            MovementType.ManualEdit => "تعديل إداري يدوي", 
            _ => "حركة غير معروفة"
        };
    }

    private async Task ShowMovements (ProductVariantListDto variant)
    {
        showMovements = true ;   
        selectedVariant = variant ;  
        var result =   await productService.VariantMovementsAsync(variant.Id) ; 
        MovementList = result.Data ; 
         
    }

}