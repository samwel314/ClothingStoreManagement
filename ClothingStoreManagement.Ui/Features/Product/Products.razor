@page "/products"

<div class="container-fluid py-4" dir="rtl">
    <!-- رأس الصفحة: العناوين والأزرار -->
    <div class="row align-items-center mb-4 g-4">
        <div class="col-lg-4 text-start">
            <div class="d-flex align-items-center justify-content-end">
                <div class="ms-4 text-end">
                    <h3 class="fw-bold mb-0 text-dark">كتالوج المنتجات</h3>
                    <p class="text-muted small mb-0">عرض وإدارة موديلات الملابس والمخزون</p>
                </div>
                <div class="bg-primary bg-opacity-10 p-3 rounded-3 shadow-sm">
                    <i class="bi bi-tags-fill text-primary fs-4"></i>
                </div>
            </div>
        </div>
        
        <!-- بار البحث الموحد (Pill Design) -->
        <div class="col-lg-5">
            <div class="input-group shadow-sm rounded-pill bg-white p-1 border">
                <button class="btn btn-primary rounded-pill px-4 fw-bold">بحث</button>
                <input type="text" class="form-control border-0 bg-transparent text-end" placeholder="ابحث باسم المنتج أو SKU...">
                <span class="input-group-text bg-transparent border-0 text-muted px-3">
                    <i class="bi bi-search"></i>
                </span>
            </div>
        </div>

        <div class="col-lg-3 text-start">
            <button class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm d-inline-flex align-items-center gap-2">
                <i class="bi bi-plus-lg"></i>
                <span>إضافة منتج جديد</span>
            </button>
        </div>
    </div>

    <!-- بطاقات الإحصائيات السريعة -->
    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-primary border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1 small">إجمالي الموديلات</h6>
                        <h4 class="fw-bold mb-0">124</h4>
                    </div>
                    <i class="bi bi-box text-primary fs-3"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-warning border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1 small">نقص في المخزون</h6>
                        <h4 class="fw-bold mb-0 text-warning">8</h4>
                    </div>
                    <i class="bi bi-exclamation-triangle text-warning fs-3"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-danger border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1 small">نفذت من المخزن</h6>
                        <h4 class="fw-bold mb-0 text-danger">3</h4>
                    </div>
                    <i class="bi bi-x-circle text-danger fs-3"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-start border-success border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1 small">إجمالي القطع</h6>
                        <h4 class="fw-bold mb-0 text-success">1,450</h4>
                    </div>
                    <i class="bi bi-graph-up-arrow text-success fs-3"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- جدول عرض المنتجات (Advanced List) -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-end" style="width: 50px;">#</th>
                        <th class="py-3 text-end">المنتج والـ SKU</th>
                        <th class="py-3 text-end">الفئة</th>
                        <th class="py-3 text-center">عدد التنوعات</th>
                        <th class="py-3 text-center">إجمالي المخزون</th>
                        <th class="py-3 text-center">نطاق السعر</th>
                        <th class="py-3 text-center">الحالة</th>
                        <th class="py-3 text-start px-4">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- مثال لمنتج واحد -->
                    <tr>
                        <td class="px-4"><button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-chevron-down"></i></button></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light p-2 rounded-3 me-3 text-center" style="width: 45px;">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                                <div class="text-end me-2">
                                    <h6 class="fw-bold mb-0">قميص كتان كاجوال</h6>
                                    <small class="text-muted">SKU: SH-101</small>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-info bg-opacity-10 text-info px-3 rounded-pill">رجالي</span></td>
                        <td class="text-center fw-bold">5 ألوان/مقاسات</td>
                        <td class="text-center">
                            <span class="text-success fw-bold">35 قطعة</span>
                        </td>
                        <td class="text-center small">450 - 520 ج.م</td>
                        <td class="text-center">
                            <span class="badge bg-success rounded-pill px-3">نشط</span>
                        </td>
                        <td class="text-start px-4">
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1">تعديل</button>
                            <button class="btn btn-sm btn-light rounded-circle"><i class="bi bi-three-dots"></i></button>
                        </td>
                    </tr>
                    
                    <!-- صف التنوعات المخفي (يظهر عند الضغط) -->
                    <tr class="bg-light bg-opacity-50">
                        <td colspan="8" class="p-0">
                            <div class="px-5 py-3">
                                <table class="table table-sm table-borderless align-middle mb-0">
                                    <thead class="small text-muted border-bottom">
                                        <tr>
                                            <th class="text-end">اللون</th>
                                            <th class="text-center">المقاس</th>
                                            <th class="text-center">سعر البيع</th>
                                            <th class="text-center">المخزون</th>
                                            <th class="text-center">الباركود الفريد</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><i class="bi bi-circle-fill text-dark me-2"></i> أسود</td>
                                            <td class="text-center">L</td>
                                            <td class="text-center fw-bold">450 ج.م</td>
                                            <td class="text-center">20 قطعة</td>
                                            <td class="text-center small text-muted">SH-101-L-BK</td>
                                        </tr>
                                        <tr>
                                            <td><i class="bi bi-circle-fill text-secondary me-2"></i> أبيض</td>
                                            <td class="text-center">XL</td>
                                            <td class="text-center fw-bold">520 ج.م</td>
                                            <td class="text-center text-danger fw-bold">2 قطعة (قرب يخلص)</td>
                                            <td class="text-center small text-muted">SH-101-XL-WH</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .card { transition: all 0.3s ease; }
    .table-hover tbody tr:hover { background-color: rgba(0,0,0,0.02); }
    .badge { font-weight: 500; font-size: 0.8rem; }
    .table thead th { font-weight: 600; font-size: 0.85rem; border-bottom-width: 0; }
    .transition-all { transition: all 0.2s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
</style>