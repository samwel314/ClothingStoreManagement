@page "/products"

<div class="container-fluid py-4 bg-light min-vh-100" dir="rtl">
    
    <div class="row align-items-center mb-5 g-4">
        <div class="col-lg-4">
            <div class="d-flex align-items-center justify-content-start">
                <div class="bg-primary bg-opacity-10 p-3 rounded-4 shadow-sm ms-3">
                    <i class="bi bi-box-seam-fill text-primary fs-4"></i>
                </div>
                <div class="text-end">
                    <h3 class="fw-bold mb-0 text-dark">إدارة المنتجات</h3>
                    <p class="text-muted small mb-0">تحكم في الكتالوج والتنوعات</p>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="input-group shadow-sm rounded-pill bg-white p-1 border">
                <button class="btn btn-primary rounded-pill px-4 fw-bold" type="button">بحث</button>
                <input type="text" class="form-control border-0 bg-transparent text-end" 
                       placeholder="ابحث باسم المنتج أو SKU..." style="box-shadow: none;">
                <span class="input-group-text bg-transparent border-0 text-muted px-3">
                    <i class="bi bi-search"></i>
                </span>
            </div>
        </div>

        <div class="col-lg-3 text-start">
            <a href="/products/create" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm d-inline-flex align-items-center gap-2 transition-all hover-lift" style="height: 48px;">
                <i class="bi bi-plus-circle fs-5"></i>
                <span>منتج جديد</span>
            </a>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0 gap-1">
                <li class="page-item"><a class="page-link border-0 shadow-sm rounded-2 text-muted" href="#"><i class="bi bi-chevron-right"></i></a></li>
                <li class="page-item active"><a class="page-link border-0 shadow-sm rounded-2 px-3" href="#">1</a></li>
                <li class="page-item"><a class="page-link border-0 shadow-sm rounded-2 px-3" href="#">2</a></li>
                <li class="page-item"><a class="page-link border-0 shadow-sm rounded-2 text-muted" href="#"><i class="bi bi-chevron-left"></i></a></li>
            </ul>
        </nav>

        <div class="d-flex gap-2">
            <select class="form-select border-0 shadow-sm rounded-pill px-4 py-2 fw-semibold small">
                <option>كل الحالات</option>
                <option>نشط</option>
                <option>غير نشط</option>
            </select>
            <select class="form-select border-0 shadow-sm rounded-pill px-4 py-2 fw-semibold small">
                <option>كل الفئات</option>
                <option>ملابس</option>
                <option>أحذية</option>
            </select>
        </div>
    </div>

    <div class="product-list">
        @for (int i = 0; i < 2; i++)
        {
<div class="product-card bg-white rounded-4 shadow-sm border-0 mb-3 overflow-hidden transition-all">
    <div class="p-4">
        <div class="row align-items-center">
            <div class="col-md-3">
                <div class="text-end">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <h5 class="fw-bold mb-0 text-dark">قميص كتان كاجوال</h5>
                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3">نشط</span>
                    </div>
                    <span class="text-muted small font-monospace">SKU: SH-LINEN-2024</span>
                </div>
            </div>

            <div class="col-md-3 text-center border-start border-end border-light">
                <span class="text-muted small d-block mb-1">الفئة</span>
                <span class="fw-semibold badge bg-light text-dark rounded-pill px-3">ملابس رجالي</span>
            </div>

            <div class="col-md-3 text-center">
                <span class="text-muted small d-block mb-1">آخر تحديث</span>
                <div class="d-flex align-items-center justify-content-center gap-1 text-dark fw-medium small">
                    <i class="bi bi-clock-history text-muted"></i>
                    <span>منذ ساعتين</span>
                </div>
            </div>

            <div class="col-md-3">
                <div class="d-flex align-items-center justify-content-end gap-3">
                    <div class="form-check form-switch m-0 p-0 d-flex align-items-center gap-2">
                        <input class="form-check-input ms-0 custom-switch" type="checkbox" checked>
                    </div>
                    <div class="d-flex gap-1">
                        <button class="btn btn-outline-danger border-0 rounded-circle p-2" title="حذف"><i class="bi bi-trash3"></i></button>
                        <button class="btn btn-outline-primary border-0 rounded-circle p-2" title="تعديل"><i class="bi bi-pencil-square"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-light bg-opacity-25 border-top p-3">
        <div class="d-flex justify-content-between align-items-center mb-2 px-2 cursor-pointer" data-bs-toggle="collapse" href="#variants-1">
            <div class="text-primary small fw-bold">
                <i class="bi bi-layers-half ms-1"></i>
                التنوعات المتاحة (4)
            </div>
            <i class="bi bi-chevron-down text-muted small"></i>
        </div>

        <div class="collapse show mt-2" id="variants-1">
            <div class="table-responsive rounded-3 border bg-white mx-2">
                <table class="table table-sm table-hover mb-0 text-end align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="py-2 pe-3 small" style="width: 30%">اللون والمقاس</th>
                            <th class="py-2 small">المخزون</th>
                            <th class="py-2 small">السعر</th>
                            <th class="py-2 small text-center">SKU فرعي</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="pe-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="shadow-sm border border-light-subtle" 
                                         style="width: 18px; height: 18px; background-color: #00FFFF; border-radius: 4px;"></div>
                                    <span class="fw-bold text-dark small">أبيض</span>
                                    <span class="text-muted">/</span>
                                    <span class="badge bg-secondary-subtle text-secondary small">XL</span>
                                </div>
                            </td>
                            <td><span class="text-success fw-bold">20 قطعة</span></td>
                            <td class="fw-medium">450 ج.م</td>
                            <td class="text-center text-muted small font-monospace">SH-LN-W-XL</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>        }
    </div>
</div>

<style>
    .rounded-4 { border-radius: 1rem !important; }
    .product-card { border: 1px solid #edf2f7 !important; }
    
    /* Toggle Switch Style */
    .custom-switch { width: 3rem !important; height: 1.5rem !important; cursor: pointer; }
    .custom-switch:checked { background-color: #198754; border-color: #198754; }

    /* Pagination Styling */
    .page-link { font-size: 0.85rem; color: #64748b; background: white; }
    .page-item.active .page-link { background-color: #0d6efd !important; color: white !important; }

    .hover-lift { transition: transform 0.2s; }
    .hover-lift:hover { transform: translateY(-3px); }

    .table thead th { font-weight: 600; color: #475569; border-bottom: 1px solid #f1f5f9; }
    .table td { vertical-align: middle; border-bottom: 1px solid #f8fafc; }
</style>