@page "/colors"
@inject ColorService ColorService
@inject AppState AppState   
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show border-0 small rounded-3 mb-3 d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-3"></i>
    
        <div class="flex-grow-1">
            &nbsp;@errorMessage
        </div>

        <button type="button" class="btn-close ms-0 me-auto" @onclick="() => errorMessage = null" aria-label="Close"></button>
    </div>
}
@if (showSuccessAlert)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4 d-flex align-items-center" role="alert" dir="rtl" style="padding-left: 3rem;">
        <i class="bi bi-check-circle-fill me-3 fs-4"></i>
        &nbsp;
        <div>
            <strong class="ms-1">تم بنجاح!</strong>
            <span>تم حفظ البيانات وتحديث القائمة بنجاح.</span>
        </div>

        <button type="button" class="btn-close ms-0 me-auto" @onclick="() => showSuccessAlert = false" aria-label="Close"></button>
    </div>
}

<div class="row align-items-center mb-4 g-4" dir="rtl">
    <div class="col-lg-4 text-start">
        <div class="d-flex align-items-center justify-content-end">
            <div class="ms-4 text-end">
                <h3 class="fw-bold mb-0 text-dark" style="letter-spacing: -0.5px;">إدارة الألوان</h3>
                <p class="text-muted small mb-0">تحكم في قائمة الألوان المتاحة للمنتجات</p>
            </div>
            <div class="bg-info bg-opacity-10 p-3 rounded-3 shadow-sm">
                <i class="bi bi-palette-fill text-info fs-4"></i>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="input-group shadow-sm rounded-pill bg-white p-1 border">
            <button @onclick="ApplyFilter"
                    class="btn btn-primary rounded-pill px-4 fw-bold"
                    type="button">
                بحث
            </button>
            
            <input @bind="searchTerm"
                   type="text"
                   class="form-control border-0 bg-transparent text-end"
                   placeholder="ابحث باسم اللون..."
                   style="box-shadow: none;">
            
                <span class="input-group-text bg-transparent border-0 text-muted px-3">
                    <i class="bi bi-search"></i>
                </span>
            </div>
        </div>

    @if (AppState.CurrentUser?.Role == UserRole.Admin)
    {
        <div class="col-lg-3 text-start">
            <button class="btn btn-success rounded-pill px-4 fw-bold shadow-sm d-inline-flex align-items-center gap-2 transition-all hover-lift"
                    @onclick="OpenAddModal"
                    style="height: 48px;">
                <i class="bi bi-plus-circle fs-5"></i>
                <span>لون جديد</span>
            </button>
        </div>

    }
    </div>
    <ColorGrid Colors="allColors" OnEdit="Edit" />

@if (isModalOpen)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 text-end" dir="rtl">
                <EditForm Model="colorModel" OnValidSubmit="HandleSaveColor">
                    <DataAnnotationsValidator />
                    
                    <div class="modal-header border-0 pb-0">
                        <h5 class="fw-bold text-primary">
                            <i class="bi bi-palette-fill ms-2"></i>
                            @(isEditMode ? "تعديل لون" : "إضافة لون جديد")
                        </h5>
                        <button type="button" class="btn-close ms-0 me-auto" @onclick="CloseModal"></button>
                    </div>

                    <div class="modal-body py-4">
          
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">اسم اللون</label>
                            <InputText @bind-Value="colorModel.Name" class="form-control form-control-lg bg-light border-0" placeholder="مثلاً: أحمر ملكي" />
                            <ValidationMessage For="@(() => colorModel.Name)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted">كود اللون (Hex)</label>
                            <div class="d-flex gap-2">
                                <InputText @bind-Value="colorModel.Code" class="form-control form-control-lg bg-light border-0" placeholder="#FF0000" />
                                <input type="color" class="form-control form-control-color border-0 p-1 bg-light"
                                       style="width: 60px; height: 48px;"
                                       @onchange="(e) => colorModel.Code = e!.Value.ToString()!"
                                       value="@colorModel.Code" />
                            </div>
                            <ValidationMessage For="@(() => colorModel.Code)" class="text-danger small mt-1" />
                        </div>
                    </div>

                    <div class="modal-footer border-0 pt-0">
                        <button type="submit" class="btn btn-primary px-5 rounded-3 fw-bold shadow-sm">حفظ البيانات</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<ColorListDTO> allColors;
    private string searchTerm = "";
    private bool isModalOpen = false;
    private bool isEditMode = false;
    private CreateUpdateColorDto colorModel = new();
    private string? errorMessage;


    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var result = await ColorService.GetColorsAsync(searchTerm) ; 
        if (result.IsSuccess)
        {
            allColors = result.Data!;
        }
        else
        {
            errorMessage = "فشل تحميل الألوان. حاول مرة أخرى لاحقاً.";
        }
    }

    private async Task OpenAddModal()
    {
        colorModel = new();
        isEditMode = false;
        isModalOpen = true;
    }

    private void Edit(ColorListDTO color)
    {
        colorModel = new CreateUpdateColorDto { Id = color.Id, Name = color.Name, Code = color.Code };
        isEditMode = true;
        isModalOpen = true;
    }

    private void CloseModal()
    {
        colorModel = new(); 
        isModalOpen = false;

    }


    private async Task HandleSaveColor()
    {

        if (isEditMode)
        {
            var result = await ColorService.UpdateColorAsync(colorModel.Id!.Value, colorModel);
            if (result.IsSuccess)
            {
                showSuccessAlert = true ;
            }
            else
            {
                errorMessage = result.ErrorMessage; 
            }

        }
        else
        {
            
            var result = await ColorService.CreateColorAsync(colorModel);
            if (result.IsSuccess)
            {
                showSuccessAlert = true;
            }
            else
            {
                errorMessage = result.ErrorMessage;
            }
        }
        await LoadData();
        CloseModal();
        StateHasChanged();
    }
    private async Task ApplyFilter()
    {
        await LoadData();   
        StateHasChanged();  
    }
    private bool showSuccessAlert = false;
}