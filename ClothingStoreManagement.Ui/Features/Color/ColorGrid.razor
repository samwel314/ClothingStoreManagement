<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4" style="width: 40%">اسم اللون</th>
                    <th style="width: 25%">كود اللون</th>
                    <th style="width: 20%">المعاينة</th>
                    <th class="text-end pe-4" style="width: 15%">الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @if (Colors != null && Colors.Any())
                {
                    @foreach (var color in Colors)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@color.Name</span>
                            </td>
                            <td>
                                <code class="bg-light p-1 rounded text-primary">@color.Code</code>
                            </td>
                            <td>
                                <div class="rounded-circle shadow-sm border"
                                     style="width: 30px; height: 30px; background-color: @color.Code;"
                                     title="@color.Name">
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm">
                                    <button class="btn btn-sm btn-white border" @onclick="() => OnEdit.InvokeAsync(color)">
                                        <i class="bi bi-pencil-square text-primary"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-palette fs-1 d-block mb-2"></i>
                            لا يوجد ألوان مضافة حالياً.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IEnumerable<ColorListDTO> Colors { get; set; } = new List<ColorListDTO>();
    [Parameter, EditorRequired] public EventCallback<ColorListDTO> OnEdit { get; set; }
}