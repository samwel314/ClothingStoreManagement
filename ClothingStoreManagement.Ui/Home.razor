@page "/"

<div class="container-fluid py-4 bg-light min-vh-100" dir="rtl">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">مرحباً 👋</h2>
            <p class="text-muted mb-0 small">نظرة سريعة على أداء النظام اليوم</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-dark rounded-4 px-4 shadow-sm">
                <i class="bi bi-receipt-cutoff ms-1"></i>
                فاتورة جديدة
            </button>

            <button class="btn btn-primary rounded-4 px-4 shadow-sm">
                <i class="bi bi-plus-circle ms-1"></i>
                إضافة منتج
            </button>
        </div>
    </div>

    <!-- Statistics -->
    <div class="row g-4 mb-4">

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <small class="text-muted">مبيعات اليوم</small>
                            <h3 class="fw-bold mt-2 mb-0">12,450 ج.م</h3>
                        </div>

                        <div class="bg-success bg-opacity-10 text-success rounded-4 p-3">
                            <i class="bi bi-cash-stack fs-4"></i>
                        </div>
                    </div>

                    <small class="text-success fw-semibold">
                        <i class="bi bi-arrow-up"></i>
                        +18% مقارنة بالأمس
                    </small>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <small class="text-muted">عدد الفواتير</small>
                            <h3 class="fw-bold mt-2 mb-0">84</h3>
                        </div>

                        <div class="bg-primary bg-opacity-10 text-primary rounded-4 p-3">
                            <i class="bi bi-receipt fs-4"></i>
                        </div>
                    </div>

                    <small class="text-muted">اليوم الحالي</small>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <small class="text-muted">المنتجات</small>
                            <h3 class="fw-bold mt-2 mb-0">1,245</h3>
                        </div>

                        <div class="bg-warning bg-opacity-10 text-warning rounded-4 p-3">
                            <i class="bi bi-box-seam fs-4"></i>
                        </div>
                    </div>

                    <small class="text-muted">إجمالي المنتجات</small>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <small class="text-muted">العملاء</small>
                            <h3 class="fw-bold mt-2 mb-0">325</h3>
                        </div>

                        <div class="bg-danger bg-opacity-10 text-danger rounded-4 p-3">
                            <i class="bi bi-people fs-4"></i>
                        </div>
                    </div>

                    <small class="text-muted">عملاء مسجلين</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts + Alerts -->
    <div class="row g-4">

        <!-- Chart -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h5 class="fw-bold mb-1">إحصائيات المبيعات 📈</h5>
                            <small class="text-muted">آخر 7 أيام</small>
                        </div>

                        <button class="btn btn-light border rounded-3 px-3">
                            <i class="bi bi-download"></i>
                        </button>
                    </div>

                    <div style="height:300px">
                        <canvas id="salesChart"></canvas>
                    </div>

                </div>
            </div>
        </div>

        <!-- Right Side -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-4">التنبيهات 🔔</h5>

                    <div class="vstack gap-3">

                        <div class="p-3 rounded-4 bg-danger bg-opacity-10 border border-danger border-opacity-25">
                            <div class="d-flex align-items-start">
                                <div class="text-danger ms-3">
                                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                                </div>

                                <div>
                                    <h6 class="fw-bold mb-1">مخزون منخفض</h6>
                                    <small class="text-muted">
                                        تيشيرت أسود — متبقي قطعتين فقط
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="p-3 rounded-4 bg-warning bg-opacity-10 border border-warning border-opacity-25">
                            <div class="d-flex align-items-start">
                                <div class="text-warning ms-3">
                                    <i class="bi bi-clock-history fs-5"></i>
                                </div>

                                <div>
                                    <h6 class="fw-bold mb-1">فاتورة معلقة</h6>
                                    <small class="text-muted">
                                        يوجد 5 فواتير لم يتم تأكيدها
                                    </small>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

            <!-- Top Products -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-4">الأكثر مبيعاً 🔥</h5>

                    <div class="vstack gap-3">

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="bg-dark text-white rounded-3 d-flex align-items-center justify-content-center"
                                     style="width:45px;height:45px;">
                                    <i class="bi bi-bag"></i>
                                </div>

                                <div class="me-3">
                                    <h6 class="mb-0 fw-bold">حذاء رياضي</h6>
                                    <small class="text-muted">120 عملية بيع</small>
                                </div>
                            </div>

                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">
                                +12%
                            </span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-3 d-flex align-items-center justify-content-center"
                                     style="width:45px;height:45px;">
                                    <i class="bi bi-phone"></i>
                                </div>

                                <div class="me-3">
                                    <h6 class="mb-0 fw-bold">سماعات بلوتوث</h6>
                                    <small class="text-muted">85 عملية بيع</small>
                                </div>
                            </div>

                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                                +8%
                            </span>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>
</div>