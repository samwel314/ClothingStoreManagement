@page "/"

<div class="container-fluid" dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h2 class="fw-bold text-dark">نظرة عامة على المتجر</h2>
        <span class="badge bg-primary p-2">اليوم: @DateTime.Now.ToString("dd/MM/yyyy")</span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-primary text-white py-3">
                <div class="card-body text-center">
                    <h6 class="card-title opacity-75">إجمالي مبيعات اليوم</h6>
                    <h2 class="display-6 fw-bold mb-0">1,550 ج.م</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-success text-white py-3">
                <div class="card-body text-center">
                    <h6 class="card-title opacity-75">عدد الفواتير</h6>
                    <h2 class="display-6 fw-bold mb-0">12</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-warning text-dark py-3">
                <div class="card-body text-center">
                    <h6 class="card-title opacity-75">الأصناف المتوفرة</h6>
                    <h2 class="display-6 fw-bold mb-0">342</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-danger text-white py-3">
                <div class="card-body text-center">
                    <h6 class="card-title opacity-75">نواقص المخزن</h6>
                    <h2 class="display-6 fw-bold mb-0">8</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">آخر عمليات البيع</h5>
                    <button class="btn btn-sm btn-outline-primary">عرض الكل</button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="px-4">رقم الفاتورة</th>
                                    <th>الوقت</th>
                                    <th>عدد القطع</th>
                                    <th>الإجمالي</th>
                                    <th class="text-center">الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="px-4 fw-bold">#5501</td>
                                    <td>02:30 م</td>
                                    <td>3 قطع</td>
                                    <td class="fw-bold">1,200 ج.م</td>
                                    <td class="text-center"><span class="badge rounded-pill bg-success-subtle text-success border border-success px-3">مكتملة</span></td>
                                </tr>
                                <tr>
                                    <td class="px-4 fw-bold">#5502</td>
                                    <td>03:15 م</td>
                                    <td>1 قطعة</td>
                                    <td class="fw-bold">450 ج.م</td>
                                    <td class="text-center"><span class="badge rounded-pill bg-success-subtle text-success border border-success px-3">مكتملة</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-dark text-white p-2">
                <div class="card-body">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">سجل النشاط</h5>
                    <div class="mb-3 small">
                        <p class="mb-1 fw-bold text-info">تنبيه مخزني</p>
                        <p class="mb-0 opacity-75">"بنطلون جينز ليكرا" وصل للحد الأدنى.</p>
                    </div>
                    <div class="mb-3 small border-top pt-2">
                        <p class="mb-1 fw-bold text-success">عملية بيع</p>
                        <p class="mb-0 opacity-75">تم إصدار فاتورة جديدة بمبلغ 1,200 ج.م</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>